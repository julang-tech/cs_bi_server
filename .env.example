APP_PORT=8787
APP_HOST=127.0.0.1
SYNC_CONFIG_PATH=config/sync/config.json
GOOGLE_APPLICATION_CREDENTIALS=config/gcp/julang-dev-database-876c2efba122.json
P1_API_BASE_URL=https://cs-mail.n8n-julang-tech-dev.com
P1_API_KEY=<cloud access key>

# 飞书登录鉴权（开发默认不启用；配置完整且 FEISHU_AUTH_ENABLED=true 或填写 app id/secret 后启用）
# FEISHU_REDIRECT_URI 是 OAuth redirect_uri，用于登录授权码回跳；不要与飞书事件订阅/长连接回调配置混淆。
FEISHU_AUTH_ENABLED=false
FEISHU_APP_ID=<feishu app id>
FEISHU_APP_SECRET=<feishu app secret>
FEISHU_REDIRECT_URI=http://127.0.0.1:8787/auth/feishu/callback
SESSION_SECRET=<至少 32 位随机字符串>
FEISHU_ALLOWED_DOMAINS=julang.com
FEISHU_AUTH_SCOPE=
AUTH_COOKIE_SECURE=false
# 未启用真实飞书鉴权时，前端水印可使用以下开发用户展示
FEISHU_DEV_USER_NAME=开发模式
FEISHU_DEV_USER_EMAIL=dev@example.com
