{
  "name": "bikanban",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:app\" \"npm:dev:client\"",
    "dev:app": "npm run build:server --silent && node server-dist/server/entrypoints/app.js",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "lint": "eslint .",
    "test:p3": "npm run build:server --silent && node server-dist/server/test/p3.test.js",
    "test:p3-api": "npm run build:server --silent && node server-dist/server/test/p3-api.test.js",
    "test:integrations": "npm run build:server --silent && node server-dist/server/test/integrations.test.js",
    "test:sync": "npm run build:server --silent && node server-dist/server/test/sync.test.js",
    "preview": "vite preview",
    "start": "node server-dist/server/entrypoints/app.js",
    "sync:preview": "npm run build:server --silent && node server-dist/server/entrypoints/sync.js preview",
    "sync:run": "npm run build:server --silent && node server-dist/server/entrypoints/sync.js sync",
    "sync:csv": "npm run build:server --silent && node server-dist/server/entrypoints/sync.js sync-csv"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@google-cloud/bigquery": "^8.1.1",
    "@types/node": "^25.6.0",
    "commander": "^14.0.3",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.9"
  }
}
